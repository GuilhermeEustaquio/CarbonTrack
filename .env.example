# URL base da API Java/Spring Boot (sem barra no final).
# Para deploy em produção, use a URL do Render:
VITE_API_BASE_URL=https://globalsolution2-java.onrender.com

# Defina como "true" para forçar o fallback local mesmo com VITE_API_BASE_URL configurada.
# Útil apenas para desenvolvimento/testes de UI sem backend ativo.
VITE_FORCE_MOCK=false

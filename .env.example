# URL base da API Java/Spring Boot (sem barra no final).
# Exemplos:
#   VITE_API_BASE_URL=https://minha-api.railway.app
#   VITE_API_BASE_URL=https://minha-api.com/api
#   VITE_API_BASE_URL=http://localhost:8080
#
# Quando configurada, o front-end usa a API real.
# Quando vazia, o front-end usa fallback local (localStorage).
VITE_API_BASE_URL=

# Defina como "true" para forçar o fallback local mesmo com VITE_API_BASE_URL configurada.
# Útil apenas para desenvolvimento/testes de UI sem backend ativo.
VITE_FORCE_MOCK=false
